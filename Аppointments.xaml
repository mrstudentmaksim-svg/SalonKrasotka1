<Window x:Class="SaloonKrasotka.Appointments"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SaloonKrasotka"
        WindowStartupLocation="CenterScreen"
        Title="Записи на прием" Height="650" Width="1200">
    <Window.Resources>
        <local:TimeConverter x:Key="TimeConverter"/>
    </Window.Resources>
    <Grid Background="#FFD9E4B6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок с логическим разделением -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Группа 1: Действия с данными -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Действия:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button x:Name="b_appointmentsShowInactive" Content="👁️ Показать неактивных" Click="b_appointmentsShowInactive_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Переключить отображение активных/неактивных записей"
                       Background="#FFE3F2FD" BorderBrush="#FF1976D2"/>
                <Button x:Name="b_appointmentsNew" Content="➕ Новая запись" Click="b_appointmentsNew_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Добавить новую запись на прием"
                       Background="#FFE8F5E8" BorderBrush="#FF2E7D32"/>
                <Button x:Name="b_appointmentsDelete" Content="🗑️ Удалить" Click="b_appointmentsDelete_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Деактивировать выбранную запись"
                       Background="#FFFCE4EC" BorderBrush="#FFC2185B"/>
                <Button x:Name="b_appointmentsReturn" Content="← Вернуться" Click="b_appointmentsReturn_Click" 
                       Margin="5,0" Padding="15,5" ToolTip="Вернуться в главное меню"
                       Background="#FFF5F5F5" BorderBrush="#FF757575" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Группа 2: Фильтры и поиск -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Поиск можно добавить при необходимости -->
            </StackPanel>

            <!-- Группа 3: Навигация -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Навигационные кнопки теперь в основной группе -->
            </StackPanel>
        </Grid>

        <!-- Таблица записей -->
        <DataGrid x:Name="appointmentsCell" Grid.Row="1" Grid.Column="0" Margin="10" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" SelectionChanged="appointmentsCell_SelectionChanged"
                  Background="White" BorderBrush="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код записи" Binding="{Binding appCode}" Width="80"/>
                <DataGridTextColumn Header="Мастер" Binding="{Binding masterName}" Width="*"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding clientName}" Width="*"/>
                <DataGridTextColumn Header="Тип услуги" Binding="{Binding servTypeName}" Width="*"/>
                <DataGridTextColumn Header="Услуга" Binding="{Binding servName}" Width="*"/>
                <DataGridTextColumn Header="Время начала" Binding="{Binding queueFrom, Converter={StaticResource TimeConverter}}" Width="100"/>
                <DataGridTextColumn Header="Время окончания" Binding="{Binding queueTo, Converter={StaticResource TimeConverter}}" Width="100"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding appDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding appointmentsActivity}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Карточка записи -->
        <Border Grid.Row="1" Grid.Column="1" Margin="10" BorderBrush="Gray" BorderThickness="1" 
                Background="White" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="15" MinHeight="400">
                    <TextBlock Text="Информация о записи" FontSize="16" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="Код записи:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock x:Name="cardAppointmentCode" Text="" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <TextBlock Text="Мастер:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardMaster" Margin="0,0,0,10" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28"
                             DisplayMemberPath="MasterName" SelectedValuePath="MasterCode"
                             SelectionChanged="cardMaster_SelectionChanged"/>

                    <TextBlock Text="Тип услуги мастера:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock x:Name="cardMasterServiceType" Text="" Margin="0,0,0,10" TextWrapping="Wrap" FontStyle="Italic"/>

                    <TextBlock Text="Клиент:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardClient" Margin="0,0,0,10" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28"
                             DisplayMemberPath="ClientName" SelectedValuePath="ClientCode"/>

                    <TextBlock Text="Тип услуги:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardServiceType" Margin="0,0,0,10" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28"
                             DisplayMemberPath="servType" SelectedValuePath="servTypeCode" 
                             SelectionChanged="cardServiceType_SelectionChanged"/>

                    <TextBlock Text="Услуга:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardService" Margin="0,0,0,10" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28"
                             DisplayMemberPath="servName" SelectedValuePath="servCode"
                             SelectionChanged="cardService_SelectionChanged"/>

                    <TextBlock Text="Время начала:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardQueueFrom" Margin="0,0,0,10" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28"
                             ToolTip="Выберите время начала записи"
                             SelectionChanged="cardQueueFrom_SelectionChanged"/>

                    <TextBlock Text="Время окончания:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="cardQueueTo" Text="" Margin="0,0,0,10" IsReadOnly="True"
                            Background="#FFF5F5F5" BorderThickness="1" Padding="5" MinHeight="25"
                            ToolTip="Рассчитывается автоматически на основе длительности услуги"/>

                    <TextBlock Text="Дата:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <DatePicker x:Name="cardAppDate" Margin="0,0,0,20" IsEnabled="False" 
                               Background="#FFF5F5F5" MinHeight="28"/>

                    <TextBlock Text="Статус:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardAppointmentActivity" Margin="0,0,0,20" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28">
                        <ComboBoxItem Content="да"/>
                        <ComboBoxItem Content="нет"/>
                    </ComboBox>

                    <!-- Кнопки управления карточкой -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="b_cardChange" Content="✏️ Изменить" Click="b_cardChange_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75"
                               Background="#FFE3F2FD" BorderBrush="#FF1976D2"/>
                        <Button x:Name="b_cardCancel" Content="❌ Отменить" Click="b_cardCancel_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75" Visibility="Collapsed"
                               Background="#FFFCE4EC" BorderBrush="#FFC2185B"/>
                        <Button x:Name="b_cardSave" Content="💾 Сохранить" Click="b_cardSave_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75" Visibility="Collapsed"
                               Background="#FFE8F5E8" BorderBrush="#FF2E7D32"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Background="#FFF5F5F5">
            <StatusBarItem>
                <TextBlock x:Name="appointmentsCountText" Text="📅 Количество записей: 0" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>