<Window x:Class="SaloonKrasotka.Services"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        Title="Услуги" Height="592" Width="995">
    <Grid Background="#FFD9E4B6" Margin="0,0,0,-16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок с логическим разделением -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Группа 1: Действия с данными -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Действия:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button x:Name="b_servicesShowInactive" Content="👁️ Показать неактивные" Click="b_servicesShowInactive_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Переключить отображение активных/неактивных услуг"
                       Background="#FFE3F2FD" BorderBrush="#FF1976D2"/>
                <Button x:Name="b_servicesNew" Content="➕ Новая услуга" Click="b_servicesNew_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Добавить новую услугу"
                       Background="#FFE8F5E8" BorderBrush="#FF2E7D32"/>
                <Button x:Name="b_servicesDelete" Content="🗑️ Удалить" Click="b_servicesDelete_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Деактивировать выбранную услугу"
                       Background="#FFFCE4EC" BorderBrush="#FFC2185B"/>
                <Button x:Name="b_servicesReturn" Content="← Вернуться" Click="b_servicesReturn_Click" 
                       Margin="5,0" Padding="15,5" ToolTip="Вернуться в главное меню"
                       Background="#FFF5F5F5" BorderBrush="#FF757575" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Группа 2: Фильтры и поиск -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Поиск можно добавить при необходимости -->
            </StackPanel>

            <!-- Группа 3: Навигация -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Навигационные кнопки теперь в основной группе -->
            </StackPanel>
        </Grid>

        <!-- Таблица услуг -->
        <DataGrid x:Name="servicesCell" Grid.Row="1" Grid.Column="0" Margin="10" AutoGenerateColumns="False"
                  IsReadOnly="True" SelectionMode="Single" SelectionChanged="servicesCell_SelectionChanged"
                  Background="White" BorderBrush="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код услуги" Binding="{Binding servCode}" Width="80"/>
                <DataGridTextColumn Header="Название услуги" Binding="{Binding servName}" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding servPrice}" Width="80"/>
                <DataGridTextColumn Header="Длительность" Binding="{Binding servDuration}" Width="100"/>
                <DataGridTextColumn Header="Тип услуги" Binding="{Binding servTypeName}" Width="*"/>
                <DataGridTextColumn Header="Активность" Binding="{Binding servicesActivity}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Карточка услуги -->
        <Border Grid.Row="1" Grid.Column="1" Margin="10" BorderBrush="Gray" BorderThickness="1" 
                Background="White" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <TextBlock Text="Информация об услуге" FontSize="16" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <TextBlock Text="Код услуги:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock x:Name="cardServiceCode" Text="" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <TextBlock Text="Название услуги:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="cardServiceName" Text="" Margin="0,0,0,10" IsReadOnly="True"
                            Background="#FFF5F5F5" BorderThickness="1" Padding="5" TextWrapping="Wrap" MinHeight="25"/>

                    <TextBlock Text="Цена:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="cardServicePrice" Text="" Margin="0,0,0,10" IsReadOnly="True"
                            Background="#FFF5F5F5" BorderThickness="1" Padding="5" TextWrapping="Wrap" MinHeight="25"/>

                    <TextBlock Text="Длительность (получасовок):" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="cardServiceDuration" Text="" Margin="0,0,0,10" IsReadOnly="True"
                            Background="#FFF5F5F5" BorderThickness="1" Padding="5" TextWrapping="Wrap" MinHeight="25"/>

                    <TextBlock Text="Тип услуги:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardServiceType" Margin="0,0,0,10" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28"
                             DisplayMemberPath="servType" SelectedValuePath="servTypeCode"/>

                    <TextBlock Text="Активность:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardServiceActivity" Margin="0,0,0,20" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28">
                        <ComboBoxItem Content="да"/>
                        <ComboBoxItem Content="нет"/>
                    </ComboBox>

                    <!-- Кнопки управления карточкой -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="b_cardChange" Content="✏️ Изменить" Click="b_cardChange_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75"
                               Background="#FFE3F2FD" BorderBrush="#FF1976D2"/>
                        <Button x:Name="b_cardCancel" Content="❌ Отменить" Click="b_cardCancel_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75" Visibility="Collapsed"
                               Background="#FFFCE4EC" BorderBrush="#FFC2185B"/>
                        <Button x:Name="b_cardSave" Content="💾 Сохранить" Click="b_cardSave_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75" Visibility="Collapsed"
                               Background="#FFE8F5E8" BorderBrush="#FF2E7D32"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="2" Grid.ColumnSpan="2" Background="#FFF5F5F5">
            <StatusBarItem>
                <TextBlock x:Name="servicesCountText" Text="💼 Количество услуг: 0" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>