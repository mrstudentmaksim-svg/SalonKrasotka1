<Window x:Class="SaloonKrasotka.OpenDB"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SaloonKrasotka"
        mc:Ignorable="d"
        Title="OpenDB" Height="450" Width="800">
    <Grid Background="#FFD9E4B6">
        <Label x:Name="l_tableWork"    Content="Работа с таблицами БД" HorizontalAlignment="Center" Height="55" Margin="0,18,0,0"  VerticalAlignment="Top"    Width="355" FontSize="30" FontWeight="Bold"/>

        <Button x:Name="b_client"      Content="Клиенты"               HorizontalAlignment="Left" Height="33" Margin="110,125,0,0"   VerticalAlignment="Top" Background="#FFA0C16B" Foreground="#333333"
        BorderThickness="2" BorderBrush="#999999"   Width="240" FontSize="20" FontWeight="Bold" Click="b_client_Click"/>
        <Button x:Name="b_typeService" Content="Типы услуг"            HorizontalAlignment="Left" Height="32" Margin="472,174,0,0"  VerticalAlignment="Top" Background="#FFA0C16B" Foreground="#333333"
        BorderThickness="2" BorderBrush="#999999"   Width="240" FontSize="20" FontWeight="Bold" Click="b_typeService_Click"/>
        <Button x:Name="b_master"      Content="Мастера"               HorizontalAlignment="Left" Height="33"    VerticalAlignment="Top" Background="#FFA0C16B" Foreground="#333333"
        BorderThickness="2" BorderBrush="#999999" Width="240" FontSize="20" FontWeight="Bold" Margin="110,192,0,0" Click="b_master_Click"/>
        <Button x:Name="b_service"     Content="Услуги"                HorizontalAlignment="Left" Height="33" Margin="472,236,0,0"  VerticalAlignment="Top" Background="#FFA0C16B" Foreground="#333333"
        BorderThickness="2" BorderBrush="#999999"   Width="240" FontSize="20" FontWeight="Bold" Click="b_service_Click"/>
        <Button x:Name="b_appoint"     Content="Оказание услуги"       HorizontalAlignment="Left" Height="32" Margin="110,263,0,0"  VerticalAlignment="Top" Background="#FFA0C16B" Foreground="#333333"
        BorderThickness="2" BorderBrush="#999999"   Width="240" FontSize="20" FontWeight="Bold" Click="b_appoint_Click"/>
        <Button x:Name="b_returnO"     Content="Вернуться"             HorizontalAlignment="Center" Height="41" Margin="0,349,0,0" VerticalAlignment="Top"  Foreground="#333333"
        BorderThickness="2" BorderBrush="#999999"   Width="160" FontSize="24" FontWeight="Bold" Click="b_returnO_Click"/>

    </Grid>
</Window>
