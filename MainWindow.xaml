<Window x:Class="SaloonKrasotka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SaloonKrasotka"
        mc:Ignorable="d"
        Title="Салон Красоты - Главное меню" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#FFD9E4B6">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,40">
            <TextBlock Text="Салон Красоты" 
                      FontSize="28" FontWeight="Bold" 
                      Foreground="#222222"/>
            <TextBlock Text="Красотка" 
                      FontSize="20" FontWeight="Bold"
                      Foreground="#444444" 
                      HorizontalAlignment="Center"
                      Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Основные кнопки -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая кнопка - БД -->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="b_db" Content="БАЗА ДАННЫХ" 
                        Height="55" Width="240"
                        FontSize="17" FontWeight="Heavy"
                        Background="#FFA0C16B" Foreground="#222222"
                        BorderThickness="3" BorderBrush="#888888"
                        Click="b_db_Click"
                        Margin="0,0,0,15"/>
                <TextBlock Text="Управление данными салона" 
                          FontSize="14" FontWeight="SemiBold"
                          Foreground="#555555" 
                          HorizontalAlignment="Center"
                          TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Правая кнопка - Администрирование -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="b_work" Content="АДМИНИСТРАТОР" 
                        Height="55" Width="240"
                        FontSize="17" FontWeight="Heavy"
                        Background="#FFA0C16B" Foreground="#222222"
                        BorderThickness="3" BorderBrush="#888888"
                        Click="b_work_Click"
                        Margin="0,0,0,15"/>
                <TextBlock Text="Ежедневное управление" 
                          FontSize="14" FontWeight="SemiBold"
                          Foreground="#555555" 
                          HorizontalAlignment="Center"
                          TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!-- Кнопка выхода -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button x:Name="b_exit" Content="ВЫХОД" 
                    Height="45" Width="140"
                    FontSize="15" FontWeight="Bold"
                    Background="#FFD1D1D1" Foreground="#222222"
                    BorderThickness="2" BorderBrush="#888888"
                    Click="b_exit_Click"/>
        </StackPanel>
    </Grid>
</Window>