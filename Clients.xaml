<Window x:Class="SaloonKrasotka.Clients"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Клиенты" Height="489" Width="900">
    <Grid Background="#FFD9E4B6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок с логическим разделением -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Группа 1: Действия с данными -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Действия:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <Button x:Name="b_clientShowInactive" Content="👁️ Показать неактивных" Click="b_clientShowInactive_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Переключить отображение активных/неактивных клиентов"
                       Background="#FFE3F2FD" BorderBrush="#FF1976D2"/>
                <Button x:Name="b_clientNew" Content="➕ Новый клиент" Click="b_clientNew_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Добавить нового клиента"
                       Background="#FFE8F5E8" BorderBrush="#FF2E7D32"/>
                <Button x:Name="b_clientDelete" Content="🗑️ Удалить" Click="b_clientDelete_Click" 
                       Margin="5,0" Padding="12,5" ToolTip="Деактивировать выбранного клиента"
                       Background="#FFFCE4EC" BorderBrush="#FFC2185B"/>
                <Button x:Name="b_clientReturn" Content="← Вернуться" Click="b_clientReturn_Click" 
                       Margin="5,0" Padding="15,5" ToolTip="Вернуться в главное меню"
                       Background="#FFF5F5F5" BorderBrush="#FF757575" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Группа 2: Фильтры и поиск -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Поиск будет здесь -->
            </StackPanel>

            <!-- Группа 3: Навигация -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Навигационные кнопки теперь в основной группе -->
            </StackPanel>
        </Grid>

        <!-- Поиск клиентов -->
        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="10,5,10,5" VerticalAlignment="Center">
            <TextBlock Text="🔍 Поиск клиентов:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
            <TextBox x:Name="searchTextBox" Width="455" Height="28" Padding="5" TextChanged="searchTextBox_TextChanged"
                     VerticalContentAlignment="Center" ToolTip="Поиск по имени или телефону клиента"/>
        </StackPanel>

        <!-- Таблица клиентов -->
        <DataGrid x:Name="clientCell" Grid.Row="2" Grid.Column="0" Margin="10" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single" SelectionChanged="clientCell_SelectionChanged"
                  MouseDoubleClick="clientCell_MouseDoubleClick" HeadersVisibility="Column"
                  Background="White" BorderBrush="LightGray">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код клиента" Binding="{Binding ClientCode}" Width="100"/>
                <DataGridTextColumn Header="Имя клиента" Binding="{Binding ClientName}" Width="*"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding ClientTel}" Width="150"/>
                <DataGridTextColumn Header="Активность" Binding="{Binding ClientsActivity}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Карточка клиента -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" Margin="10" BorderBrush="Gray" BorderThickness="1" 
                Background="White" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15">
                    <TextBlock Text="Информация о клиенте" FontSize="16" FontWeight="Bold" 
                              HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <!-- Код клиента -->
                    <TextBlock Text="Код клиента:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBlock x:Name="cardClientCode" Text="" Margin="0,0,0,10" TextWrapping="Wrap"/>

                    <!-- Имя клиента -->
                    <TextBlock Text="Имя клиента:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="cardClientName" Text="" Margin="0,0,0,10" IsReadOnly="True"
                            Background="#FFF5F5F5" BorderThickness="1" Padding="5" TextWrapping="Wrap" MinHeight="25"/>

                    <!-- Телефон клиента -->
                    <TextBlock Text="Телефон:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="cardClientTel" Text="" Margin="0,0,0,10" IsReadOnly="True"
                            Background="#FFF5F5F5" BorderThickness="1" Padding="5" TextWrapping="Wrap" MinHeight="25"/>

                    <!-- Активность клиента -->
                    <TextBlock Text="Активность:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <ComboBox x:Name="cardClientsActivity" Margin="0,0,0,20" IsEnabled="False" 
                             Background="#FFF5F5F5" MinHeight="28">
                        <ComboBoxItem Content="да"/>
                        <ComboBoxItem Content="нет"/>
                    </ComboBox>

                    <!-- Кнопки изменения -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button x:Name="b_cardChange" Content="✏️ Изменить" Click="b_cardChange_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75"
                               Background="#FFE3F2FD" BorderBrush="#FF1976D2"/>
                        <Button x:Name="b_cardCancel" Content="❌ Отменить" Click="b_cardCancel_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75" Visibility="Collapsed"
                               Background="#FFFCE4EC" BorderBrush="#FFC2185B"/>
                        <Button x:Name="b_cardSave" Content="💾 Сохранить" Click="b_cardSave_Click" 
                               Padding="12,6" Margin="5,0" MinWidth="75" Visibility="Collapsed"
                               Background="#FFE8F5E8" BorderBrush="#FF2E7D32"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Строка статуса -->
        <StatusBar Grid.Row="3" Grid.ColumnSpan="2" Background="#FFF5F5F5">
            <StatusBarItem>
                <TextBlock x:Name="clientCountText" Text="👥 Количество клиентов: 0" FontWeight="SemiBold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>